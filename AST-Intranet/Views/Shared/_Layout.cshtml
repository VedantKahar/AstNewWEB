<!-- Views/Shared/_Layout.cshtml -->
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>

    <link rel="stylesheet" href="~/Content/css/HeaderFooterStyles.css" />
</head>
<body>

    <!-- Render Header -->
    @Html.Partial("_Header")

    <div class="main-content">
        <!-- Content of the page will go here -->
        <div class="content">
            @RenderBody() <!-- This will render the content from the current view -->
        </div>

        <!-- Render Footer -->
        @Html.Partial("_Footer")
    </div>

    <!-- Inline JavaScript -->
    <script>
        // Function to handle fetching search suggestions
        function fetchSuggestions(query) {
            if (query.length < 2) { // Only fetch if the query has 2 or more characters
                document.getElementById('suggestions-box').style.display = 'none';
                return;
            }

            // Make AJAX call to the server to fetch search suggestions
            $.ajax({
                url: '/Search/GetSuggestions', // URL to the search controller action
                method: 'GET',
                data: { query: query },
                success: function (data) {
                    // Show the suggestions box
                    let suggestionsBox = document.getElementById('suggestions-box');
                    suggestionsBox.innerHTML = ''; // Clear existing suggestions

                    // If no results, hide the box
                    if (data.length === 0) {
                        suggestionsBox.style.display = 'none';
                        return;
                    }

                    // Display results
                    data.forEach(function (item) {
                        let suggestion = document.createElement('div');
                        suggestion.classList.add('suggestion-item');
                        suggestion.innerHTML = `
                    <strong>${item.page}</strong><br>
                    ${item.suggestions.join('<br>')}
                `;
                        suggestionsBox.appendChild(suggestion);
                    });

                    suggestionsBox.style.display = 'block'; // Show suggestions box
                },
                error: function () {
                    console.error('Error fetching search suggestions');
                }
            });
        }

        
    </script>
</body>
</html>
